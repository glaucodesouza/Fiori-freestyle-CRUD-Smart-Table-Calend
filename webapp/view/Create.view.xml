<mvc:View controllerName="cadmatv2.controller.Create"
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
	xmlns="sap.m"
	xmlns:f="sap.ui.layout.form"
	xmlns:l="sap.ui.layout"
	xmlns:semantic="sap.f.semantic">

	<semantic:SemanticPage
		id="objectPage2"
		showFooter="true"
		headerPinnable="false"
		toggleHeaderOnTitleClick="false"
		busy="{objectView>/busy}"
		busyIndicatorDelay="{objectView>/delay}">

		<semantic:titleHeading>
			<Title id="_IDGenTitle12"
				text="{Bukrs}"
				level="H2"/>
		</semantic:titleHeading>

		<semantic:headerContent>
			<ObjectNumber id="_IDGenObjectNumber12"
				unit="{Matnr}"
			/>
		</semantic:headerContent>

		<l:VerticalLayout id="_IDGenVerticalLayout2" width="100%">
            <f:SimpleForm id="_IDGenSimpleForm2"
                editable="true"
                layout="ResponsiveGridLayout"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="3"
                labelSpanS="12"
                adjustLabelSpan="false"
                emptySpanXL="4"
                emptySpanL="4"
                emptySpanM="4"
                emptySpanS="0"
                columnsXL="1"
                columnsL="1"
                columnsM="1"
                singleContainerFullSize="false"
                >
                
                <Label id="_IDGenLabel20" text="Empresa" />
                <Input 
                    id='txtCreateBukrs' 
                    value="" 
                />

                <Label id="_IDGenLabel12" text="Material" />
                <Input  
                    id='txtCreateMatnr'
                    value=""
                />

                <Label id="_IDGenLabel22" text="Descrição" />
                <Input  
                    id='txtCreateMaktx'
                    value=""
                />	
                
                <Label id="_IDGenLabel32" text="Quantidade" />
                <Input  
                    id='txtCreateMenge'
                    value=""
                />

                <Label id="_IDGenLabel42" text="UM" />
                <Input
                    id='txtCreateMeins'
                    value=""
                />
            </f:SimpleForm>					

	    </l:VerticalLayout>

        <!-- Custom Footer Content-->
        <semantic:footerCustomActions>
            <Button id="_IDGenButton82" type="Reject" text="Cancelar" press="onCancelar" />
        </semantic:footerCustomActions>	

	</semantic:SemanticPage>

</mvc:View>