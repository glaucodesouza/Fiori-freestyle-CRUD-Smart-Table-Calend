<mvc:View controllerName="cadmatv2.controller.Update"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:semantic="sap.f.semantic">

    <semantic:SemanticPage id="updatePage" showFooter="true">
        <semantic:titleHeading>
            <Title id="_IDGenTitle3" text="Editar Material: {Matnr}" level="H2"/>
        </semantic:titleHeading>

        <semantic:content>
            <l:VerticalLayout id="_IDGenVerticalLayout1" width="100%">
                <f:SimpleForm id="_IDGenSimpleForm1" editable="true" layout="ResponsiveGridLayout">
                    <Label id="_IDGenLabel5" text="Empresa" />
                    <Input id="_IDGenInput" value="{Bukrs}" editable="false" /> 
                    
                    <Label id="_IDGenLabel6" text="Material" />
                    <Input id="_IDGenInput1" value="{Matnr}" editable="false" />

                    <Label id="_IDGenLabel7" text="Descrição" />
                    <Input id="_IDGenInput2" value="{Maktx}" />
                    
                    <Label id="_IDGenLabel8" text="Quantidade" />
                    <Input id="_IDGenInput3" value="{Menge}" />

                    <Label id="_IDGenLabel9" text="Unidade de Medida" />
                    <Input id="_IDGenInput4" value="{Meins}" />

                    <Label id="_IDGenLabel10" text="Início da promoção" />
                    <DatePicker
                        id='txtCreateDatapromoini3'
                        displayFormat="dd/MM/yyyy"
                        valueFormat="yyyy-MM-ddTHH:mm:ss"
                        placeholder="DD/MM/AAAA"
                        value="{Datapromoini}"
                    />

                    <Label id="_IDGenLabel11" text="Fim da promoção" />
                    <DatePicker
                        id='txtCreateDatapromofim3'
                        displayFormat="dd/MM/yyyy"
                        valueFormat="yyyy-MM-ddTHH:mm:ss"
                        placeholder="DD/MM/AAAA"
                        value="{Datapromofim}"
                    />

                </f:SimpleForm>
            </l:VerticalLayout>
        </semantic:content>

        <semantic:footerCustomActions>
            <Button id="_IDGenButton" type="Emphasized" text="Salvar" press="onGravar" />
            <Button id="_IDGenButton1" text="Cancelar" press="onCancelar" />
        </semantic:footerCustomActions>
    </semantic:SemanticPage>
</mvc:View>