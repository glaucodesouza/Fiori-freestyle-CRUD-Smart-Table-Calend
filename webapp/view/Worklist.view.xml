<mvc:View controllerName="cadmatv2.controller.Worklist"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:smartTable="sap.ui.comp.smarttable"
    xmlns:fb="sap.ui.comp.filterbar"
    height="100%">

    <f:DynamicPage id="dynamicPage">
        <f:title>
            <f:DynamicPageTitle id="_IDGenDynamicPageTitle1" >
                <f:heading>
                    <Title id="_IDGenTitle" text="Gestão de Materiais (ZGCAD_MAT270)"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>

        <f:header>
            <f:DynamicPageHeader id="_IDGenDynamicPageHeader" >
                <f:content>

                <fb:FilterBar id="filterBar" header="Filtros" search=".onSearch" showRestoreButton="true">
                    <fb:filterGroupItems>
                        <fb:FilterGroupItem id="_IDGenFilterGroupItem" 
                            name="Bukrs" 
                            label="Empresa" 
                            groupName="Group1" 
                            visibleInFilterBar="true">
                            <fb:control>
                                <Input id="inputBukrs" placeholder="Digite a empresa..." maxLength="4" />
                            </fb:control>
                        </fb:FilterGroupItem>

                        <fb:FilterGroupItem id="_IDGenFilterGroupItem1" 
                            name="Matnr" 
                            label="Material" 
                            groupName="Group1" 
                            visibleInFilterBar="true">
                            <fb:control>
                                <Input id="inputMatnr" placeholder="Digite o código do material..." />
                            </fb:control>
                        </fb:FilterGroupItem>

                    </fb:filterGroupItems>
                </fb:FilterBar>

                </f:content>
            </f:DynamicPageHeader>
        </f:header>

        <f:content>
            <smartTable:SmartTable 
                id="smartTable"
                entitySet="MaterialSet"
                tableType="ResponsiveTable"
                enableExport="true"
                useVariantManagement="true"
                useTablePersonalisation="true"
                header="Lista de Materiais"
                showRowCount="true"
                enableAutoBinding="true"
                class="sapUiResponsiveContentPadding"
                persistencyKey="SmartFilter_Explored"
                beforeRebindTable="onBeforeRebindTable"
                initiallyVisibleFields="Bukrs,Matnr,Maktx,Menge,Meins,Datapromoini,Datapromofim">
                
                <smartTable:layoutData>
                    <FlexItemData id="_IDGenFlexItemData" growFactor="1" baseSize="0%"/>
                </smartTable:layoutData>
                
                <Table 
                    id="_IDGenTable"
                    mode="SingleSelectLeft"    
                    >
                    <headerToolbar>
                        <OverflowToolbar id="idOFT">
                            <ToolbarSpacer id="idTBS" />
                            <Button id='idCreateButton' class='sapUiSmallMarginBeginEnd' type="Accept" icon="sap-icon://create" text="Criar"    press="onCriar"/>
                            <Button id='idDeleleButton' class='sapUiSmallMarginBeginEnd' type="Reject" icon="sap-icon://delete" text="Deletar"  press="onDeletar"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <columns>
                        </columns>
                    <items>
                        <ColumnListItem id="_IDGenColumnListItem" type="Navigation" press="onTableLinePress"/>
                    </items>
                </Table>
            </smartTable:SmartTable>
        </f:content>
    </f:DynamicPage>
</mvc:View>
