<mvc:View controllerName="cadmatv2.controller.Calendario"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:semantic="sap.f.semantic"
    xmlns:unified="sap.ui.unified">

    <semantic:SemanticPage id="calendarioPage" showFooter="true">
        <semantic:titleHeading>
            <Title id="_IDGenTitle34" text="Editar Material: {Matnr}" level="H2"/>
        </semantic:titleHeading>

        <semantic:content>
            <l:VerticalLayout id="_IDGenVerticalLayout4"  width="100%">
			<VBox id="_IDGenVBox1" class="sapUiSmallMargin">
                <PlanningCalendar
                    id="PC0"
                    startDate="{path: 'calendar>/startDate'}"
                    rows="{path: 'calendar>/matnr'}"
                    appointmentsVisualization="Filled"
                    appointmentSelect="handleAppointmentSelect"
                    calendarWeekNumbering="{/calendarWeekNumbering}"
                    showEmptyIntervalHeaders="false"
                    showWeekNumbers="true">
                    <rows>
                        <PlanningCalendarRow id="_IDGenPlanningCalendarRow"
                            icon="{calendar>pic}"
                            title="{calendar>name}"
                            text="{calendar>role}"
                            appointments="{path : 'calendar>appointments', templateShareable: false}">
                            <customData>
                                <core:CustomData id="_IDGenCustomData" key="emp-name" value="{calendar>name}" writeToDom="true"/>
                            </customData>
                            <appointments>
                                <unified:CalendarAppointment id="_IDGenCalendarAppointment"
                                    startDate="{calendar>start}"
                                    endDate="{calendar>end}"
                                    icon="{calendar>pic}"
                                    title="{calendar>title}"
                                    type="{calendar>type}"
                                    tentative="{calendar>tentative}">
                                </unified:CalendarAppointment>
                            </appointments>
                        </PlanningCalendarRow>
                    </rows>
                </PlanningCalendar>
            </VBox>
            </l:VerticalLayout>
        </semantic:content>

        <semantic:footerCustomActions>
            <Button id="_IDGenButton2" type="Emphasized" text="Salvar" press="onGravar" />
            <Button id="_IDGenButton3" text="Cancelar" press="onCancelar" />
        </semantic:footerCustomActions>
    </semantic:SemanticPage>
</mvc:View>